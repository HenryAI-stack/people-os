# Copy to .env for local development — never commit the real .env file.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

VITE_GITHUB_OWNER=
VITE_GITHUB_REPO=people-os-data
VITE_GITHUB_TOKEN=
VITE_GITHUB_BRANCH=main

# 32+ character secret used for AES-256 encryption of all records.
# This must NEVER change once you have real data, or it becomes unreadable.
VITE_ENCRYPTION_SECRET=

# Optional: restrict logins to your company's Google Workspace domain.
VITE_ALLOWED_DOMAIN=
